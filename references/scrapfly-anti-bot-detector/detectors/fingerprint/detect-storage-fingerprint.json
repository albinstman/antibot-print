{
  "id": "detect-storage-fingerprint",
  "name": "Web Storage Fingerprint",
  "author": "Scrapfly",
  "enabled": true,
  "category": "Fingerprint",
  "lastUpdated": "2025-01-21",
  "version": "1.0",
  "website": "https://developer.mozilla.org/en-US/docs/Web/API/Web_Storage_API",
  "icon": "storage_fingerprint.png",
  "description": "Web Storage API (localStorage/sessionStorage) detection for persistent fingerprinting",
  "detection": {
    "js_hooks": [
      {
        "description": "Stores data in localStorage/sessionStorage",
        "enabled": true,
        "confidence": 80,
        "target": "Storage.prototype.setItem"
      },
      {
        "description": "Retrieves stored data",
        "enabled": true,
        "confidence": 80,
        "target": "Storage.prototype.getItem"
      },
      {
        "description": "Clears all stored data",
        "enabled": true,
        "confidence": 80,
        "target": "Storage.prototype.clear"
      }
    ],
    "window": [
      {
        "path": "localStorage",
        "description": "Persistent local storage",
        "condition": "typeof object"
      },
      {
        "path": "sessionStorage",
        "description": "Session storage",
        "condition": "typeof object"
      }
    ],
    "content": [
      {
        "text": "localStorage.setItem",
        "scope": "scripts",
        "description": "Local storage usage for fingerprinting",
        "confidence": 50,
        "textRegex": false,
        "textWholeWord": false,
        "textCaseSensitive": false
      },
      {
        "text": "sessionStorage",
        "scope": "scripts",
        "description": "Session storage access",
        "confidence": 50,
        "textRegex": false,
        "textWholeWord": false,
        "textCaseSensitive": false
      },
      {
        "text": "Storage.prototype",
        "scope": "scripts",
        "description": "Storage API usage",
        "confidence": 50,
        "textRegex": false,
        "textWholeWord": false,
        "textCaseSensitive": false
      }
    ]
  }
}

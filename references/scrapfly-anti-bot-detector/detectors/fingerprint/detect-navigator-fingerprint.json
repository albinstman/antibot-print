{
  "id": "detect-navigator-fingerprint",
  "name": "Navigator Fingerprint",
  "author": "Scrapfly",
  "enabled": true,
  "category": "Fingerprint",
  "lastUpdated": "2025-01-15",
  "version": "1.0",
  "website": "https://developer.mozilla.org/en-US/docs/Web/API/Navigator",
  "icon": "navigator_fingerprint.png",
  "description": "Browser navigator object fingerprinting to identify user agent, platform, language, and hardware details",
  "detection": {
    "js_hooks": [
      {
        "description": "Reads browser user agent string",
        "enabled": true,
        "confidence": 80,
        "target": "Navigator.prototype.userAgent"
      },
      {
        "description": "Reads operating system platform",
        "enabled": true,
        "confidence": 80,
        "target": "Navigator.prototype.platform"
      },
      {
        "description": "Detects automated browsing (Selenium, Puppeteer)",
        "enabled": true,
        "confidence": 80,
        "target": "Navigator.prototype.webdriver"
      },
      {
        "description": "Reads browser product name",
        "enabled": false,
        "confidence": 70,
        "target": "Navigator.prototype.product"
      },
      {
        "description": "Reads browser language preferences",
        "enabled": true,
        "confidence": 80,
        "target": "Navigator.prototype.languages"
      },
      {
        "description": "Reads CPU core count",
        "enabled": true,
        "confidence": 80,
        "target": "Navigator.prototype.hardwareConcurrency"
      },
      {
        "description": "Reads device memory (RAM) in GB",
        "enabled": true,
        "confidence": 80,
        "target": "Navigator.prototype.deviceMemory"
      },
      {
        "description": "Reads high entropy user agent client hints",
        "enabled": true,
        "confidence": 80,
        "target": "NavigatorUAData.prototype.getHighEntropyValues"
      }
    ]
  }
}

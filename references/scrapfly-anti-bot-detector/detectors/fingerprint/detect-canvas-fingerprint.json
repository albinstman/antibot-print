{
  "id": "detect-canvas-fingerprint",
  "name": "Canvas Fingerprint",
  "author": "Scrapfly",
  "enabled": true,
  "category": "Fingerprint",
  "lastUpdated": "2026-02-04",
  "version": "1.0.1",
  "website": "https://en.wikipedia.org/wiki/Canvas_fingerprinting",
  "icon": "canvas_fingerprint.png",
  "description": "HTML5 Canvas-based browser and device fingerprinting",
  "detection": {
    "js_hooks": [
      {
        "description": "Converts canvas to data URL for fingerprinting",
        "enabled": true,
        "confidence": 100,
        "target": "HTMLCanvasElement.prototype.toDataURL"
      },
      {
        "description": "Extracts pixel data from canvas",
        "enabled": true,
        "confidence": 100,
        "target": "CanvasRenderingContext2D.prototype.getImageData"
      },
      {
        "description": "Converts canvas to blob for fingerprinting",
        "enabled": true,
        "confidence": 85,
        "target": "HTMLCanvasElement.prototype.toBlob"
      },
      {
        "description": "Measures text dimensions for font fingerprinting",
        "enabled": true,
        "confidence": 85,
        "target": "CanvasRenderingContext2D.prototype.measureText"
      },
      {
        "description": "Creates offscreen canvas context for hidden fingerprinting",
        "enabled": true,
        "confidence": 100,
        "target": "OffscreenCanvas.prototype.getContext"
      }
    ]
  }
}

{
  "id": "detect-css-fingerprint",
  "name": "CSS Fingerprint",
  "author": "Scrapfly",
  "enabled": true,
  "category": "Fingerprint",
  "lastUpdated": "2025-01-21",
  "version": "1.0",
  "website": "https://en.wikipedia.org/wiki/CSS_fingerprinting",
  "icon": "css_fingerprint.png",
  "description": "CSS property support and computed style detection for device fingerprinting",
  "detection": {
    "js_hooks": [
      {
        "description": "Retrieves computed CSS styles for fingerprinting (disabled - getComputedStyle is on window object, not Window.prototype)",
        "enabled": false,
        "confidence": 80,
        "target": "Window.prototype.getComputedStyle"
      },
      {
        "description": "Gets CSS property values for feature detection",
        "enabled": true,
        "confidence": 80,
        "target": "CSSStyleDeclaration.prototype.getPropertyValue"
      }
    ],
    "window": [
      {
        "path": "CSS.supports",
        "description": "CSS.supports() method for CSS feature detection",
        "condition": "typeof function"
      }
    ],
    "content": [
      {
        "text": "CSS.supports(",
        "scope": "scripts",
        "description": "CSS feature detection in scripts",
        "confidence": 50,
        "textRegex": false,
        "textWholeWord": false,
        "textCaseSensitive": false
      },
      {
        "text": "getComputedStyle",
        "scope": "scripts",
        "description": "Computing element styles for fingerprinting",
        "confidence": 50,
        "textRegex": false,
        "textWholeWord": false,
        "textCaseSensitive": false
      }
    ]
  }
}

{
  "id": "detect-screen-fingerprint",
  "name": "Screen Fingerprint",
  "author": "Scrapfly",
  "enabled": true,
  "category": "Fingerprint",
  "lastUpdated": "2025-01-15",
  "version": "1.0",
  "website": "https://developer.mozilla.org/en-US/docs/Web/API/Screen",
  "icon": "screen_fingerprint.png",
  "description": "Screen and display properties fingerprinting including dimensions, color depth, and pixel ratio",
  "detection": {
    "js_hooks": [
      {
        "description": "Reads screen width for display fingerprinting",
        "enabled": true,
        "confidence": 80,
        "target": "Screen.prototype.width"
      },
      {
        "description": "Reads screen height for display fingerprinting",
        "enabled": true,
        "confidence": 80,
        "target": "Screen.prototype.height"
      },
      {
        "description": "Reads available screen height",
        "enabled": true,
        "confidence": 80,
        "target": "Screen.prototype.availHeight"
      },
      {
        "description": "Reads screen color depth",
        "enabled": true,
        "confidence": 80,
        "target": "Screen.prototype.colorDepth"
      },
      {
        "description": "Reads window inner height",
        "enabled": false,
        "confidence": 70,
        "target": "window.innerHeight"
      },
      {
        "description": "Reads device pixel ratio for high-DPI detection",
        "enabled": true,
        "confidence": 80,
        "target": "window.devicePixelRatio"
      }
    ]
  }
}

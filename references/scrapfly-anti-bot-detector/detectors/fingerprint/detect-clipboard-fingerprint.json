{
  "id": "detect-clipboard-fingerprint",
  "name": "Clipboard API Fingerprint",
  "author": "Scrapfly",
  "enabled": true,
  "category": "Fingerprint",
  "lastUpdated": "2025-01-21",
  "version": "1.0",
  "website": "https://developer.mozilla.org/en-US/docs/Web/API/Clipboard_API",
  "icon": "clipboard_fingerprint.png",
  "description": "Clipboard API access used for fingerprinting clipboard contents and capabilities",
  "detection": {
    "js_hooks": [
      {
        "description": "Reads clipboard contents for fingerprinting",
        "enabled": true,
        "confidence": 65,
        "target": "Clipboard.prototype.read"
      },
      {
        "description": "Reads plain text from clipboard",
        "enabled": true,
        "confidence": 65,
        "target": "Clipboard.prototype.readText"
      },
      {
        "description": "Writes to clipboard for capability detection",
        "enabled": true,
        "confidence": 65,
        "target": "Clipboard.prototype.write"
      }
    ],
    "window": [
      {
        "path": "navigator.clipboard",
        "description": "Clipboard API access point",
        "condition": "typeof object"
      }
    ],
    "content": [
      {
        "text": "navigator.clipboard",
        "scope": "scripts",
        "description": "Clipboard API usage",
        "confidence": 50,
        "textRegex": false,
        "textWholeWord": false,
        "textCaseSensitive": false
      },
      {
        "text": "readText",
        "scope": "scripts",
        "description": "Clipboard read operations",
        "confidence": 50,
        "textRegex": false,
        "textWholeWord": false,
        "textCaseSensitive": false
      }
    ]
  }
}

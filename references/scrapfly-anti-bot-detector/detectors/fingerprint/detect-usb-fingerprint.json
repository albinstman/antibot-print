{
  "id": "detect-usb-fingerprint",
  "name": "USB API Fingerprint",
  "author": "Scrapfly",
  "enabled": true,
  "category": "Fingerprint",
  "lastUpdated": "2025-01-21",
  "version": "1.0",
  "website": "https://developer.mozilla.org/en-US/docs/Web/API/USB_API",
  "icon": "usb_fingerprint.png",
  "description": "WebUSB API access for detecting connected USB devices and device enumeration",
  "detection": {
    "js_hooks": [
      {
        "description": "Gets list of connected USB devices",
        "enabled": true,
        "confidence": 80,
        "target": "USB.getDevices"
      },
      {
        "description": "Requests user to select USB device",
        "enabled": true,
        "confidence": 80,
        "target": "USB.requestDevice"
      }
    ],
    "window": [
      {
        "path": "navigator.usb",
        "description": "WebUSB API access point",
        "condition": "typeof object"
      },
      {
        "path": "navigator.usb.getDevices",
        "description": "USB device enumeration method",
        "condition": "typeof function"
      }
    ],
    "content": [
      {
        "text": "navigator.usb",
        "scope": "scripts",
        "description": "WebUSB API usage",
        "confidence": 50,
        "textRegex": false,
        "textWholeWord": false,
        "textCaseSensitive": false
      },
      {
        "text": "getDevices",
        "scope": "scripts",
        "description": "USB device enumeration",
        "confidence": 50,
        "textRegex": false,
        "textWholeWord": false,
        "textCaseSensitive": false
      },
      {
        "text": "requestDevice",
        "scope": "scripts",
        "description": "USB device request in scripts",
        "confidence": 50,
        "textRegex": false,
        "textWholeWord": false,
        "textCaseSensitive": false
      }
    ]
  }
}

{
  "id": "detect-performance-fingerprint",
  "name": "Performance Fingerprint",
  "author": "Scrapfly",
  "enabled": true,
  "category": "Fingerprint",
  "lastUpdated": "2025-01-15",
  "version": "1.0",
  "website": "https://developer.mozilla.org/en-US/docs/Web/API/Performance",
  "icon": "performance_fingerprint.png",
  "description": "Performance timing and resource measurement fingerprinting for device and network profiling",
  "detection": {
    "js_hooks": [
      {
        "description": "Reads high-resolution timestamps for timing analysis",
        "enabled": true,
        "confidence": 80,
        "target": "Performance.prototype.now"
      },
      {
        "description": "Accesses navigation timing data (deprecated API)",
        "enabled": false,
        "confidence": 80,
        "target": "Performance.prototype.timing"
      },
      {
        "description": "Reads memory usage statistics",
        "enabled": true,
        "confidence": 80,
        "target": "Performance.prototype.memory"
      },
      {
        "description": "Retrieves performance entries by type",
        "enabled": true,
        "confidence": 80,
        "target": "Performance.prototype.getEntriesByType"
      },
      {
        "description": "Reads performance entry start time",
        "enabled": false,
        "confidence": 75,
        "target": "PerformanceEntry.prototype.startTime"
      },
      {
        "description": "Reads connection timing for network fingerprinting",
        "enabled": false,
        "confidence": 80,
        "target": "PerformanceResourceTiming.prototype.connectEnd"
      },
      {
        "description": "Reads connection start time",
        "enabled": false,
        "confidence": 80,
        "target": "PerformanceResourceTiming.prototype.connectStart"
      },
      {
        "description": "Reads decoded resource size",
        "enabled": false,
        "confidence": 75,
        "target": "PerformanceResourceTiming.prototype.decodedBodySize"
      },
      {
        "description": "Reads domain lookup end time",
        "enabled": false,
        "confidence": 75,
        "target": "PerformanceResourceTiming.prototype.domainLookupEnd"
      },
      {
        "description": "Reads domain lookup start time",
        "enabled": false,
        "confidence": 75,
        "target": "PerformanceResourceTiming.prototype.domainLookupStart"
      },
      {
        "description": "Reads response end time",
        "enabled": false,
        "confidence": 75,
        "target": "PerformanceResourceTiming.prototype.responseEnd"
      },
      {
        "description": "Reads TLS handshake start time",
        "enabled": false,
        "confidence": 80,
        "target": "PerformanceResourceTiming.prototype.secureConnectionStart"
      },
      {
        "description": "Reads transfer size including headers",
        "enabled": false,
        "confidence": 75,
        "target": "PerformanceResourceTiming.prototype.transferSize"
      },
      {
        "description": "Reads navigation start timestamp",
        "enabled": false,
        "confidence": 75,
        "target": "PerformanceTiming.prototype.navigationStart"
      }
    ]
  }
}

        "value": "\\|1\\|[01]\\|",
        "nameRegex": true,
        "valueRegex": true,
        "confidence": 95,
        "description": "Shape Security cookie (exact 8-char name; value contains |1|0| or |1|1| marker)",
        "nameWholeWord": false,
        "nameCaseSensitive": false,
        "valueWholeWord": false,
        "valueCaseSensitive": false,
        "nameScope": "all",
        "valueScope": "all"

{
  "id": "detect-datadome",
  "name": "DataDome",
  "author": "Scrapfly",
  "enabled": true,
  "category": "Anti-Bot",
  "lastUpdated": "2024-01-15",
  "version": "1.0",
  "website": "https://datadome.co/",
  "icon": "datadome_official.png",
  "description": "Real-time bot protection with machine learning-based detection",
  "detection": {
    "cookie": [
      {
        "name": "^datadome$",
        "confidence": 100,
        "description": "Main DataDome tracking cookie",
        "nameRegex": true,
        "nameWholeWord": false,
        "nameCaseSensitive": false,
        "value": "",
        "valueRegex": false,
        "valueWholeWord": false,
        "valueCaseSensitive": false,
        "nameScope": "all",
        "valueScope": "all"
      }
    ],
    "header": [
      {
        "name": "^x-datadome-cid$",
        "confidence": 100,
        "description": "DataDome client ID header",
        "nameRegex": true,
        "nameWholeWord": false,
        "nameCaseSensitive": false,
        "value": "",
        "valueRegex": false,
        "valueWholeWord": false,
        "valueCaseSensitive": false,
        "nameScope": "response",
        "valueScope": "response"
      }
    ],
    "url": [],
    "content": [],
    "dom": [],
    "window": []
  }
}
